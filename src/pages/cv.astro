---
import PageHeading from "../components/page-heading.astro";
import Layout from "../layouts/main.astro";
---

<Layout title="CV — Krishnkant Swarnkar">
  <section class="relative z-20 max-w-4xl mx-auto my-12 px-7 lg:px-0">
    <div class="flex items-start justify-between flex-wrap gap-4">
      <PageHeading
        title="Curriculum Vitae"
        description="My background, experience, and skills."
      />
      <a
        href="/assets/KrishnkantSwarnkarCV.pdf"
        download
        class="inline-flex items-center gap-2 px-4 py-2 mt-2 text-sm font-semibold duration-300 ease-out border rounded-full bg-neutral-900 dark:bg-white dark:text-neutral-900 text-neutral-100 hover:border-neutral-700 border-neutral-900 dark:hover:border-neutral-300 hover:bg-white dark:hover:bg-black dark:hover:text-white hover:text-neutral-900"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
        </svg>
        Download PDF
      </a>
    </div>

    <div class="mt-8 w-full rounded-xl overflow-hidden border border-neutral-200 dark:border-neutral-700">
      <iframe
        src="/assets/KrishnkantSwarnkarCV.pdf#navpanes=0"
        class="w-full"
        style="height: 85vh; min-height: 600px;"
        title="Krishnkant Swarnkar CV"
      ></iframe>
    </div>
  </section>
</Layout>
