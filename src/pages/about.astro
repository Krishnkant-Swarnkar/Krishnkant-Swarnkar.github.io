---
import experiences from "../collections/experiences.json";
import AboutExperience from "../components/about-experience.astro";
import PageHeading from "../components/page-heading.astro";
import Layout from "../layouts/main.astro";
---

<Layout title="About — Krishnkant Swarnkar">
  <section class="relative z-20 max-w-2xl mx-auto my-12 px-7 lg:px-0">
    <PageHeading
      title="About Me"
      description="Hello 👋 I'm Krishnkant, an AI Research Engineer passionate about NLP, large language models, and building intelligent systems."
    />

    <img src="/assets/images/profile.jpg" class="relative z-30 w-full my-10 rounded-xl object-cover object-top max-h-[500px]" />

    <h2 class="mb-2 text-2xl font-bold dark:text-neutral-200">Short Bio</h2>
    <p
      class="text-sm leading-6 text-gray-600 dark:text-neutral-400 sm:leading-7 lg:leading-8 sm:text-base lg:text-lg"
    >
      I'm an AI Research Engineer at AlphaSense, where I work on NLP and machine learning applied to financial intelligence.
      I started coding during college — tinkering with games and web apps — and gradually found my way into deep learning and research.
      Outside of work, I enjoy music, art, and exploring ideas across disciplines.
    </p>

    <h2
      class="mt-5 mb-2 text-2xl font-bold lg:mt-10 sm:mt-6 dark:text-neutral-200"
    >
      Experience
    </h2>
    <div class="px-5 py-10">
      {
        experiences.map((experience) => {
          return (
            <div class="pb-10 border-l border-gray-200 last:border-l-0 dark:border-neutral-700">
              <AboutExperience
                dates={experience.dates}
                role={experience.role}
                company={experience.company}
                description={experience.description}
                logo={experience.logo}
              />
            </div>
          )
        })
      }
    </div>

    <h2 class="mt-5 mb-2 text-2xl font-bold lg:mt-10 sm:mt-6 dark:text-neutral-200">Let's Connect</h2>
    <p
      class="text-sm leading-6 text-gray-600 dark:text-neutral-400 sm:leading-7 lg:leading-8 sm:text-base lg:text-lg"
    >
      Find me on
      <a href="https://github.com/Krishnkant-Swarnkar" target="_blank" class="text-indigo-600 underline">GitHub</a>,
      <a href="https://www.linkedin.com/in/krishnkant-swarnkar/" target="_blank" class="text-indigo-600 underline">LinkedIn</a>, or
      <a href="https://x.com/krishnkant98" target="_blank" class="text-indigo-600 underline">X</a>
      — always happy to connect.
    </p>
  </section>
</Layout>
